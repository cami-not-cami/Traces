@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="max-w-5xl mx-auto py-12 px-4">
    <div class="mb-10 border-b border-gray-200 pb-5">
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">@ViewData["Title"]</h1>
        <p class="text-sm text-gray-500 mt-1">Join Traces and start organizing your adventures.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-start">

        <div class="md:col-span-5 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-5">
                <h2 class="text-xl font-bold text-gray-800">Create a new account.</h2>

                <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-600 p-3 rounded-xl text-sm" role="alert"></div>

                <div>
                    <label asp-for="Input.Email" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">Email Address</label>
                    <input asp-for="Input.Email" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-gray-900 placeholder-gray-400 transition-all text-sm" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="block text-xs text-red-600 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">Password</label>
                    <input asp-for="Input.Password" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-gray-900 placeholder-gray-400 transition-all text-sm" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="block text-xs text-red-600 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-gray-900 placeholder-gray-400 transition-all text-sm" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="block text-xs text-red-600 mt-1"></span>
                </div>

                <button id="registerSubmit" type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-md text-sm font-semibold text-white bg-gradient-to-r from-indigo-600 to-indigo-700 hover:from-indigo-700 hover:to-indigo-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all transform active:scale-[0.98]">
                    Register
                </button>
            </form>
        </div>

        <div class="md:col-span-6 md:col-start-7 bg-gray-50 rounded-2xl p-6 border border-gray-200/60">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Use another service to register.</h3>
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div class="text-sm text-gray-600 leading-relaxed bg-white border border-gray-200 p-4 rounded-xl">
                        There are no external authentication services configured. Coming soon!
                    </div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="flex flex-wrap gap-3">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="inline-flex items-center px-4 py-2.5 border border-gray-300 rounded-xl shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    <span class="mr-2">👤</span> @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}