@model Traces.Models.Checklist

@{
    ViewData["Title"] = "Delete Checklist";
}

<h1>Delete Checklist</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Checklist</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.ChIdPk</dd>

        <dt class="col-sm-2">Trip</dt>
        <dd class="col-sm-10">@Model.TripFkNavigation?.Title</dd>

        <dt class="col-sm-2">Content</dt>
        <dd class="col-sm-10">@Model.Content</dd>

        <dt class="col-sm-2">Completed</dt>
        <dd class="col-sm-10">@(Model.IsCompleted == true ? "Yes" : "No")</dd>

        <dt class="col-sm-2">Order</dt>
        <dd class="col-sm-10">@Model.OrderIndex</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="ChIdPk" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
