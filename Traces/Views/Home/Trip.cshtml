@{
    
    ViewData["Title"] = "Trip Dashboard";
}

<!-- ROOT WRAPPER: Fixed height full-screen container to maintain three-column layout -->
<div class="flex h-screen w-full overflow-hidden bg-gray-50 text-gray-800">

    <!-- 1. SIDEBAR (RENDERED VIA PARTIAL VIEW) -->
   
    <partial name="_SideMenuPartial.cshtml" />

    <!-- 2. MIDDLE DASHBOARD CONTENT CONTAINER -->
    <main class="flex-1 flex flex-col relative overflow-hidden h-full">

        <!-- Fixed View Header -->
        <header class="h-14 bg-white/90 backdrop-blur-md border-b border-gray-200 flex items-center justify-between px-4 sticky top-0 z-20 shrink-0">
            <div class="flex items-center space-x-4 text-sm text-gray-600">
                <button class="flex items-center hover:text-gray-900"><span class="mr-1">↩</span> Undo</button>
                <button class="flex items-center hover:text-gray-900 opacity-50"><span class="mr-1">↪</span> Redo</button>
            </div>
            <div class="flex items-center space-x-2">
                <button class="bg-gray-100 hover:bg-gray-200 text-gray-800 px-3 py-1.5 rounded-md text-sm font-medium flex items-center">
                    Trip plan <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <button class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-1.5 rounded-md text-sm font-medium flex items-center">
                    <span class="mr-2">➦</span> Share
                </button>
                <button class="p-1.5 text-gray-600 hover:bg-gray-100 rounded-md">🖼</button>
                <button class="p-1.5 text-gray-600 hover:bg-gray-100 rounded-md">☰</button>
                <button class="p-1.5 text-gray-600 hover:bg-gray-100 rounded-md">•••</button>
            </div>
        </header>

        <!-- Main Body Scroll Area -->
        <div class="flex-1 overflow-y-auto">
            <!-- Banner Cover -->
            <div class="h-64 bg-gray-300 w-full bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1523482580672-f109ba8cb9be?auto=format&fit=crop&w=1600&q=80');"></div>

            <div class="max-w-4xl mx-auto px-6 -mt-20 relative z-10 pb-12">
                <!-- Trip Destination Badge -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 flex justify-between items-end mb-10">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900 mb-4">Trip to Australia</h1>
                        <div class="flex items-center text-gray-500 text-sm">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            7/5 - 9/5
                        </div>
                    </div>
                    <div class="flex -space-x-2">
                        <img class="w-8 h-8 rounded-full border-2 border-white" src="https://i.pravatar.cc/100?img=1" alt="Avatar">
                        <div class="w-8 h-8 rounded-full border-2 border-white bg-gray-100 flex items-center justify-center text-xs text-gray-600">
                            +👤
                        </div>
                    </div>
                </div>

                <!-- Section: Discover / Explore -->
                <div class="mb-8">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-xl font-bold text-gray-900 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            Explore
                        </h2>
                        <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-1.5 rounded-full text-sm font-medium flex items-center shadow-sm">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Browse all
                        </button>
                    </div>

                    <!-- Cards Layout Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 relative">
                        <!-- Card Variant 1 -->
                        <div>
                            <div class="h-32 bg-gray-200 rounded-xl mb-3 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1506973035872-a4ec16b8e8d9?auto=format&fit=crop&w=400&q=80');"></div>
                            <h3 class="font-semibold text-gray-900 text-sm mb-1 leading-tight">Fly With Liz's Oceania Adventure</h3>
                            <p class="text-xs text-gray-500 mb-2">Popular guide by a Wanderlog community member</p>
                            <div class="flex items-center text-xs text-gray-600">
                                <img class="w-5 h-5 rounded-full mr-2" src="https://i.pravatar.cc/100?img=5" alt=""> Fly With Liz
                            </div>
                        </div>
                        <!-- Card Variant 2 -->
                        <div>
                            <div class="h-32 bg-gray-200 rounded-xl mb-3 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1542315750-f1c713b6329c?auto=format&fit=crop&w=400&q=80');"></div>
                            <h3 class="font-semibold text-gray-900 text-sm mb-1 leading-tight">Allan Watt's 🪸 Cairns & the Great Barrier Reef</h3>
                            <p class="text-xs text-gray-500 mb-2">Popular guide by a Wanderlog community member</p>
                            <div class="flex items-center text-xs text-gray-600">
                                <img class="w-5 h-5 rounded-full mr-2" src="https://i.pravatar.cc/100?img=8" alt=""> Allan Watt
                            </div>
                        </div>
                        <!-- Card Variant 3 -->
                        <div>
                            <div class="h-32 bg-gray-200 rounded-xl mb-3 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&w=400&q=80');"></div>
                            <h3 class="font-semibold text-gray-900 text-sm mb-1 leading-tight">Search hotels with transparent pricing</h3>
                            <p class="text-xs text-gray-500 mb-2">Unlike most sites, we don't sort based on commissions</p>
                            <div class="flex items-center text-xs text-gray-600 font-medium text-red-500">
                                <span class="bg-red-500 text-white w-4 h-4 rounded-full inline-flex items-center justify-center text-[10px] mr-1.5">W</span> Wanderlog
                            </div>
                        </div>

                        <!-- Mini Carousel Pagination Next Trigger Button -->
                        <button class="absolute -right-4 top-12 bg-white rounded-full p-2 shadow-md border border-gray-100 text-gray-500">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>

                <!-- Footer Summary Metric Widgets Info Row -->
                <div class="flex flex-col sm:flex-row gap-4">
                    <!-- Reservation Management Widgets Card Matrix -->
                    <div class="bg-gray-100 rounded-xl p-5 flex-1">
                        <h3 class="font-bold text-gray-900 text-sm mb-4">Reservations and attachments</h3>
                        <div class="flex space-x-6 overflow-x-auto pb-2">
                            <div class="flex flex-col items-center cursor-pointer opacity-70 hover:opacity-100 shrink-0">
                                <span class="text-xl mb-1">✈️</span><span class="text-[10px] font-medium text-gray-600 uppercase">Flight</span>
                            </div>
                            <div class="flex flex-col items-center cursor-pointer opacity-70 hover:opacity-100 shrink-0">
                                <span class="text-xl mb-1">🛏️</span><span class="text-[10px] font-medium text-gray-600 uppercase">Lodging</span>
                            </div>
                            <div class="flex flex-col items-center cursor-pointer opacity-70 hover:opacity-100 shrink-0">
                                <span class="text-xl mb-1">🚗</span><span class="text-[10px] font-medium text-gray-600 uppercase">Rental car</span>
                            </div>
                            <div class="flex flex-col items-center cursor-pointer opacity-70 hover:opacity-100 shrink-0">
                                <span class="text-xl mb-1">🚆</span><span class="text-[10px] font-medium text-gray-600 uppercase">Train</span>
                            </div>
                            <div class="flex flex-col items-center cursor-pointer shrink-0">
                                <div class="relative">
                                    <span class="text-xl mb-1 block">📎</span>
                                    <div class="w-2 h-2 bg-yellow-500 rounded-full absolute -top-1 -right-1 border border-white"></div>
                                </div>
                                <span class="text-[10px] font-medium text-gray-600 uppercase">Attachment</span>
                            </div>
                            <div class="flex flex-col items-center cursor-pointer opacity-70 hover:opacity-100 shrink-0">
                                <span class="text-xl mb-1">•••</span><span class="text-[10px] font-medium text-gray-600 uppercase">Other</span>
                            </div>
                        </div>
                    </div>

                    <!-- Budget Allocation Widget Panel Card -->
                    <div class="bg-gray-100 rounded-xl p-5 w-full sm:w-48 shrink-0 flex flex-col justify-center">
                        <h3 class="font-bold text-gray-900 text-sm mb-1">Budgeting</h3>
                        <div class="text-2xl font-bold text-gray-900 mb-1">0,00 €</div>
                        <a href="#" class="text-xs text-blue-600 hover:underline">View details</a>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- 3. RIGHT HAND SIDE INTERACTIVE MAP FRAME CONTAINER -->
    <aside class="hidden lg:block w-[45%] bg-gray-200 border-l border-gray-300 relative h-full">
        <iframe src="https://maps.google.com/maps?q=Sydney,Australia&t=&z=13&ie=UTF8&iwloc=&output=embed"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </aside>
</div>