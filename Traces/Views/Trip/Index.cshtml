                        </div>
                        <div class="flex items-start text-sm text-slate-600">
                            <span class="mr-2 text-base shrink-0">📍</span>
                            <span id="modal-address" class="leading-relaxed">Address info</span>
                        </div>
                    </div>
                    <div class="space-y-2 text-sm text-slate-600 sm:border-l border-slate-100 sm:pl-6 flex flex-col justify-center">
                        <div id="modal-phone-container" class="flex items-center">
                            <span class="mr-2 text-base">📞</span>
                            <span id="modal-phone">No phone number available</span>
                        </div>
                        <div id="modal-website-container" class="flex items-center mt-1">
                            <span class="mr-2 text-base">🌐</span>
                            <a id="modal-website" href="#" target="_blank" class="text-indigo-600 hover:text-indigo-805 hover:underline font-semibold break-all">Visit Website</a>
                        </div>
                    </div>
                </div>

                <!-- Editorial Summary -->
                <div id="modal-summary-container" class="space-y-2 hidden">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">About</h3>
                    <p id="modal-summary" class="text-slate-600 text-sm leading-relaxed"></p>
                </div>

                <!-- Opening Hours -->
                <div id="modal-hours-container" class="space-y-2 border-t border-slate-100 pt-5 hidden">
                    <button onclick="toggleModalHours()" class="w-full flex items-center justify-between text-left text-xs font-bold text-slate-450 uppercase tracking-wider focus:outline-none">
                        <span>Opening Hours</span>
                        <svg id="hours-arrow" class="w-4 h-4 text-slate-505 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    <div id="modal-hours" class="hidden text-xs text-slate-600 space-y-1.5 pt-2 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1"></div>
                </div>

                <!-- Reviews -->
                <div id="modal-reviews-container" class="space-y-4 border-t border-slate-100 pt-5 hidden">
                    <h3 class="text-xs font-bold text-slate-455 uppercase tracking-wider">Recent Reviews</h3>
                    <div id="modal-reviews" class="space-y-4 divide-y divide-slate-100"></div>
                </div>
            </div>
        </div>
        </div>

   </div>
<div id="invite-member-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 p-4 backdrop-blur-sm hidden">

    <div class="w-full max-w-md overflow-hidden rounded-xl bg-white shadow-2xl transition-all">

        <div class="relative px-6 pt-6 pb-4">
            <h3 class="text-xl font-semibold text-gray-900">Manage Trip Members</h3>
            <p class="mt-1 text-sm text-gray-500">Collaborators who have access to this trip.</p>

            <button onclick="closeInviteModal()" class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Current Members List -->
        <div class="px-6 py-2 max-h-48 overflow-y-auto space-y-2 border-b border-gray-100 pb-4">
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Current Collaborators</label>
            @if (Model.Members != null && Model.Members.Any())
            {
                foreach (var member in Model.Members)
                {
                    <div class="flex items-center justify-between bg-slate-50 p-2 rounded-lg text-sm">
                        <div class="flex items-center space-x-2 truncate">
                            <div class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-700 font-bold flex items-center justify-center text-xs shrink-0">
                                @((!string.IsNullOrEmpty(member.Email) ? member.Email[0].ToString() : "U").ToUpper())
                            </div>
                            <span class="text-gray-700 truncate" title="@member.Email">@member.Email</span>
                        </div>
                        @if (!Model.ViewOnly)
                        {
                            <button type="button" onclick="confirmRemoveMember(@Model.TripId, @member.TripMemberId, '@member.Email')" class="text-rose-500 hover:text-rose-700 text-xs font-semibold px-2 py-1 rounded hover:bg-rose-50 transition-colors shrink-0">
                                Remove
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-xs text-slate-400 italic">No members added yet.</p>
            }
        </div>

        <form id="invite-member-form" class="space-y-4">
            <div class="px-6 py-4">
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Invite New Collaborator (Email)</label>
                <input type="email"
                       id="email"
                       name="email"
                       placeholder="tripmember@email.com"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                       required />
            </div>

            <div class="bg-gray-50 px-6 py-4 flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-3 space-y-2 space-y-reverse sm:space-y-0">
                <button type="button" onclick="closeInviteModal()"
                        class="w-full sm:w-auto px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Close
                </button>
                <button type="submit"
                        class="w-full sm:w-auto px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-sm">
                    Send Invite
                </button>
            </div>
        </form>

    </div>
</div>

<!-- ADD EXPENSE MODAL -->
<div id="add-expense-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 p-4 backdrop-blur-sm hidden">
    <div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-2xl transition-all border border-slate-100 flex flex-col max-h-[90vh]">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h3 class="text-lg font-black text-slate-800">Add expense</h3>
            <button onclick="closeAddExpenseModal()" class="text-slate-400 hover:text-slate-650 transition-colors focus:outline-none">
                <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <form id="add-expense-form" class="flex-1 overflow-y-auto p-6 space-y-4">
            <input type="hidden" name="tripId" value="@Model.TripId" />

            <!-- Amount Input (Wanderlog style) -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Amount (€)</label>
                <div class="relative flex items-center rounded-xl bg-slate-50 border border-slate-200 focus-within:ring-2 focus-within:ring-indigo-500/20 focus-within:border-indigo-500 focus-within:bg-white transition-all overflow-hidden">
                    <span class="pl-4 text-slate-500 font-bold text-base">€</span>
                    <input type="number" step="0.01" min="0.01" name="amount" placeholder="0.00" required
                           class="w-full pl-2 pr-4 py-3 bg-transparent text-slate-800 font-black text-base outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
                </div>
            </div>

            <!-- Title / Item Description -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Description</label>
                <input type="text" name="title" placeholder="e.g. Dinner, Train ticket, Entrance fee" required
                       class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm placeholder-slate-400 outline-none transition-all" />
            </div>

            <!-- Category Select -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Category</label>
                <select name="category" required
                        class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm outline-none transition-all">
                    <option value="Food & Drink">🍔 Food & Drink</option>
                    <option value="Lodging">🏨 Lodging</option>
                    <option value="Transit">🚌 Transit</option>
                    <option value="Sightseeing">🏛️ Sightseeing</option>
                    <option value="Activities">🎡 Activities</option>
                    <option value="Shopping">🛍️ Shopping</option>
                    <option value="Flights">✈️ Flights</option>
                    <option value="Other">💳 Miscellaneous</option>
                </select>
            </div>

            <!-- Paid By Select -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Paid By</label>
                <select name="paidByUserIdPk" required
                        class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm outline-none transition-all">
                    @foreach (var member in Model.Members)
                    {
                        <option value="@member.TripMemberId">👤 @member.Email</option>
                    }
                </select>
            </div>

            <!-- Split Options -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Split</label>
                <select name="splitType" required
                        class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm outline-none transition-all">
                    <option value="Split equally">Split equally among all members</option>
                    <option value="Don't split">Don't split (Only for payer)</option>
                </select>
            </div>

            <!-- Date (Optional) -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Date (Optional)</label>
                <input type="date" name="date" 
                       class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm outline-none transition-all" />
            </div>

            <!-- Associated Itinerary Item (Select Item Dropdown) -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Link to Activity (Optional)</label>
                <select name="tripActivityFk"
                        class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm outline-none transition-all">
                    <option value="">-- None --</option>
                    @foreach (var day in Model.Days)
                    {
                        var dayLabel = day.DayLabel;
                        foreach (var act in day.Activities)
                        {
                            <option value="@act.TripActivityId">[@dayLabel] @act.Place?.Name</option>
                        }
                    }
                </select>
            </div>

            <!-- Submit buttons -->
            <div class="flex justify-end space-x-3 pt-4 border-t border-slate-100 mt-6 bg-slate-50 -mx-6 -mb-6 px-6 py-4">
                <button type="button" onclick="closeAddExpenseModal()"
                        class="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-600 rounded-xl text-sm font-semibold transition-all">
                    Cancel
                </button>
                <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-5 py-2 rounded-xl text-sm font-semibold shadow-sm transition-all">
                    Save Expense
                </button>
            </div>
        </form>
    </div>
</div>

<!-- CATEGORY BREAKDOWN MODAL -->
<div id="expense-breakdown-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 p-4 backdrop-blur-sm hidden">
    <div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-2xl transition-all border border-slate-100 flex flex-col max-h-[90vh]">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h3 class="text-lg font-black text-slate-800">Expense Breakdown</h3>
            <button onclick="closeBreakdownModal()" class="text-slate-400 hover:text-slate-600 transition-colors focus:outline-none">
                <svg class="w-5.5 h-5.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Scrollable content -->
        <div class="p-6 overflow-y-auto space-y-6">
            <!-- Summary stats -->
            <div class="bg-indigo-50/50 rounded-2xl p-5 border border-indigo-100 flex justify-between items-center shadow-sm">
                <div>
                    <h4 class="text-xs font-bold text-indigo-700 uppercase tracking-wider mb-1">Total Expenses</h4>
                    <span id="breakdown-total-spent" class="text-2xl font-black text-indigo-900">€0.00</span>
                </div>
                <div class="text-right">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Limit Status</h4>
                    <span id="breakdown-limit-percentage" class="text-sm font-black text-slate-700">0% Used</span>
                </div>
            </div>

            <!-- List of Category Stats (populated dynamically via JS) -->
            <div id="breakdown-categories-list" class="space-y-4">
                <!-- Dynamically built rows will go here -->
            </div>
        </div>

        <div class="bg-slate-50 px-6 py-4 flex justify-end border-t border-slate-100">
            <button type="button" onclick="closeBreakdownModal()"
                    class="px-5 py-2 bg-white border border-slate-200 hover:bg-slate-50 text-slate-650 rounded-xl text-sm font-semibold transition-all shadow-sm">
                Close
            </button>
        </div>
    </div>
</div>

<!-- REUSABLE CONFIRMATION MODAL -->
<div id="confirmation-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/60 p-4 backdrop-blur-sm hidden">
    <div class="w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-2xl transition-all border border-slate-100">
        <div class="p-6">
            <div class="flex items-center space-x-3 mb-4">
                <div id="confirm-modal-icon" class="w-10 h-10 rounded-full bg-rose-50 flex items-center justify-center text-rose-600 shrink-0">
                    <!-- Icon is set dynamically -->
                </div>
                <h3 id="confirm-modal-title" class="text-lg font-bold text-slate-900">Are you sure?</h3>
            </div>
            <p id="confirm-modal-message" class="text-sm text-slate-500 mb-6 leading-relaxed">This action cannot be undone.</p>
            <div class="flex justify-end space-x-3">
                <button id="confirm-modal-cancel" type="button" class="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-600 rounded-xl text-sm font-semibold transition-all">
                    Cancel
                </button>
                <button id="confirm-modal-confirm" type="button" class="px-4 py-2 bg-rose-600 hover:bg-rose-700 text-white rounded-xl text-sm font-semibold shadow-sm transition-all">
                    Confirm
                </button>
            </div>
        </div>
    </div>
</div>

   <script>
    window.TripConfig = {
        googleApiKey: '@Configuration["ApiKeys:GoogleApiKey"]',
        tripId: @Model.TripId,
        viewOnly: @(Model.ViewOnly ? "true" : "false"),
        currentUserIdPk: @(ViewBag.CurrentUserIdPk ?? 0),
        currentUserEmail: '@(ViewBag.CurrentUserEmail ?? "")',
        expenses: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Expenses ?? new List<ExpenseViewModel>())),
        latitude: @(Model.Latitude?.ToString("G", System.Globalization.CultureInfo.InvariantCulture) ?? "47.200"),
        longitude: @(Model.Longitude?.ToString("G", System.Globalization.CultureInfo.InvariantCulture) ?? "13.200"),
        hasCoords: @(Model.Latitude.HasValue && Model.Longitude.HasValue ? "true" : "false"),
        firstPlaceId: '@(Model.PlacesToVisit?.FirstOrDefault()?.GooglePlaceId)',
        updateDetailsUrl: '@Url.Action("UpdateTripDetails", "Trip")',
        setBudgetUrl: '@Url.Action("SetBudget", "Trip")',
        inviteMemberUrl: '@Url.Action("InviteTripMember", "Trip")',
        deleteTripUrl: '@Url.Action("DeleteTrip", "Trip")',
        removeMemberUrl: '@Url.Action("RemoveTripMember", "Trip")',
        updateTravelModeUrl: '@Url.Action("UpdateTravelMode", "Trip")',
        places: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (Model.PlacesToVisit ?? new List<PlaceViewModel>())
            .Concat((Model.Days ?? new List<TripDayViewModel>()).SelectMany(d => d.Activities ?? new List<TripActivityViewModel>()).Where(a => a.Place != null).Select(a => a.Place))
            .Where(p => p != null && p.Latitude.HasValue && p.Longitude.HasValue)
            .Select(p => new
            {
                name = p.Name,
                lat = (double)p.Latitude.Value,
                lng = (double)p.Longitude.Value,
                category = p.PrimaryCategory
            })
        )),
        routes: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (Model.Days ?? new List<TripDayViewModel>())
            .SelectMany(d => d.Activities ?? new List<TripActivityViewModel>())
            .Where(a => a.RouteToNext != null && !string.IsNullOrEmpty(a.RouteToNext.PolylineEncoded))
            .Select(a => new
            {
                fromActivityId = a.TripActivityId,
                toActivityId = a.RouteToNext.ToActivityFk,
                polyline = a.RouteToNext.PolylineEncoded,
                travelMode = a.RouteToNext.TravelMode,
                distance = a.RouteToNext.DistanceMeters,
                duration = a.RouteToNext.DurationSeconds
            })
        ))
    };
    </script>

@section Scripts {
    <script src="~/js/tripScript.js" asp-append-version="true"></script>
    <script async
            src="https://maps.googleapis.com/maps/api/js?key=@Configuration["ApiKeys:GoogleApiKey"]&libraries=places,geometry&loading=async&callback=initMap">
    </script>
}