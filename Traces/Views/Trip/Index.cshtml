@inject IConfiguration Configuration
@model CreateTripViewModel
@{
    ViewData["Title"] = "Trip Dashboard";
    ViewData["FullBleed"] = true;
}

<style>
    .activity-card.dragging {
        opacity: 0.4;
        border-color: #6366f1 !important; /* indigo-500 */
        box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.1), 0 4px 6px -2px rgba(99, 102, 241, 0.05);
        transform: scale(0.98);
    }

    .activities-container {
        min-height: 80px;
        border: 2px dashed transparent;
        border-radius: 1rem;
        transition: all 0.2s ease;
    }

    .activities-container:empty {
        border: 2px dashed #e2e8f0; /* slate-200 */
        background-color: #f8fafc; /* slate-50 */
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80px;
    }

    .activities-container:empty::after {
        content: "Drag activities here";
        color: #94a3b8; /* slate-400 */
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .activities-container.drag-over {
        background-color: rgba(99, 102, 241, 0.05) !important;
        border: 2px dashed #6366f1 !important; /* indigo-500 */
        padding: 0.75rem;
    }

    .drag-handle {
        align-self: center;
    }
</style>

<!-- ROOT WRAPPER: Fixed height full-screen container to maintain layout -->
<div class="flex flex-col md:flex-row h-[calc(100vh-64px)] w-full overflow-hidden bg-slate-50 text-slate-800 font-sans relative">

    <!-- Mobile Sidebar Backdrop Overlay -->
    <div id="sidebar-overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/40 z-30 hidden transition-opacity duration-300"></div>

    <!-- 1. SIDEBAR (RENDERED VIA PARTIAL VIEW) -->
    <partial name="_SideMenuPartial.cshtml" />

    <!-- 2. MIDDLE DASHBOARD CONTENT CONTAINER -->
    <main class="flex-1 flex flex-col relative overflow-hidden h-[55%] md:h-full bg-white shadow-xl z-10">

        <!-- Fixed View Header -->
        <header class="h-16 bg-slate-50/95 backdrop-blur-md border-b border-slate-200/60 flex items-center justify-between px-4 sm:px-6 sticky top-0 z-20 shrink-0">
            <div class="flex items-center space-x-2 sm:space-x-3 text-sm text-slate-500 font-medium">
                <button onclick="toggleSidebar()" class="md:hidden flex items-center justify-center p-2 rounded-xl text-slate-500 hover:bg-slate-200/60 hover:text-slate-800 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <span class="font-bold text-slate-700">Itinerary Planner</span>
            </div>

            <div class="flex items-center space-x-1.5 sm:space-x-3">

                
                @if (Model.TripId == 0)
                {
                    <form asp-controller="Trip" asp-action="Save" method="post" class="inline m-0">
                        <input type="hidden" asp-for="TripId" />
                        <input type="hidden" asp-for="Title" />
                        <input type="hidden" asp-for="Description" />
                        <input type="hidden" asp-for="StartDate" />
                        <input type="hidden" asp-for="EndDate" />
                        <input type="hidden" asp-for="Budget" />

                        @if (Model.PlacesToVisit != null)
                        {
                            for (int i = 0; i < Model.PlacesToVisit.Count; i++)
                            {
                                <input type="hidden" name="PlacesToVisit[@i].GooglePlaceId" value="@Model.PlacesToVisit[i].GooglePlaceId" />
                                <input type="hidden" name="PlacesToVisit[@i].Name" value="@Model.PlacesToVisit[i].Name" />
                                <input type="hidden" name="PlacesToVisit[@i].Latitude" value="@Model.PlacesToVisit[i].Latitude" />
                                <input type="hidden" name="PlacesToVisit[@i].Longitude" value="@Model.PlacesToVisit[i].Longitude" />
                                <input type="hidden" name="PlacesToVisit[@i].FormattedAddress" value="@Model.PlacesToVisit[i].FormattedAddress" />
                                <input type="hidden" name="PlacesToVisit[@i].PrimaryCategory" value="@Model.PlacesToVisit[i].PrimaryCategory" />
                                <input type="hidden" name="PlacesToVisit[@i].City" value="@Model.PlacesToVisit[i].City" />
                                <input type="hidden" name="PlacesToVisit[@i].CoverPhoto" value="@Model.PlacesToVisit[i].CoverPhoto" />
                            }
                        }

                        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 hover:shadow-lg hover:shadow-emerald-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                            <svg class="w-4 h-4 sm:mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                            </svg>
                            <span class="hidden sm:inline">Save</span>
                        </button>
                    </form>
                }

                <button class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                    <svg class="w-4 h-4 sm:mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.73 2.837m0-7.158l-4.73 2.837M19 12a3 3 0 11-6 0 3 3 0 016 0zm-12 6a3 3 0 11-6 0 3 3 0 016 0zm0-12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="hidden sm:inline">Share</span>
                </button>
            </div>
        </header>

        <!-- Main Body Scroll Area -->
        <div class="flex-1 overflow-y-auto">
            <!-- Banner Cover -->
            @{
                string coverUrl;
                if (ViewBag.CoverPhoto != null)
                {
                    coverUrl = $"https://places.googleapis.com/v1/{ViewBag.CoverPhoto}/media?key={Configuration["ApiKeys:GoogleApiKey"]}&maxWidthPx=1600";
                }
                else
                {
                    var query = Model.Title;
                    if (query != null)
                    {
                        if (query.StartsWith("Trip to ", StringComparison.OrdinalIgnoreCase))
                        {
                            query = query.Substring(8);
                        }

                    }
                    coverUrl = !string.IsNullOrEmpty(query)
                             ? $"https://source.unsplash.com/1600x900/?{Uri.EscapeDataString(query)},travel"
                             : Url.Content("~/default_cover_photo.jpg");

                }
            }
            <div class="h-64 bg-slate-200 w-full bg-cover bg-center relative" style="background-image: url('@coverUrl');">
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>

            <div class="max-w-3xl mx-auto px-6 -mt-20 relative z-10 pb-20">

                <!-- Trip Destination Badge -->
                <div class="bg-white rounded-2xl shadow-xl shadow-slate-100/80 border border-slate-100 p-8 mb-12 transform transition-all duration-300 hover:shadow-2xl relative">
                    
                    <!-- Read-Only View -->
                    <div id="trip-badge-view" class="flex flex-col sm:flex-row justify-between items-start sm:items-end w-full">
                        <div class="mb-4 sm:mb-0 pr-8 relative group flex-1">
                            <div class="flex items-center gap-3">
                                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-2">@Model.Title</h1>
                                <button onclick="enterBadgeEditMode()" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-slate-105 rounded-lg transition-all" title="Edit Trip Details">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                    </svg>
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <p class="text-slate-500 text-sm mb-3 leading-relaxed">@Model.Description</p>
                            }
                            <div class="flex items-center text-slate-500 text-sm font-medium mt-1">
                                <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                @(Model.StartDate?.ToString("MMM dd, yyyy") ?? "Start Date") - @(Model.EndDate?.ToString("MMM dd, yyyy") ?? "End Date")
                            </div>
                        </div>
                        <div class="flex items-center space-x-2 shrink-0">
                            <div class="flex -space-x-2">
                                @foreach (var member in Model.Members.Take(3))
                                {
                                    var initial1 = !string.IsNullOrEmpty(member.FirstName) ? member.FirstName[0].ToString() : "";
                                    var initial2 = !string.IsNullOrEmpty(member.LastName) ? member.LastName[0].ToString() : "";
                                    var initials = (initial1 + initial2).ToUpper();
                                    if (string.IsNullOrEmpty(initials)) initials = "U";
                                    <div class="w-9 h-9 rounded-full border-2 border-white bg-indigo-150 flex items-center justify-center text-xs font-bold text-indigo-700 shadow-md" title="@member.FullName">
                                        @initials
                                    </div>
                                }
                            </div>
                            <div class="w-9 h-9 rounded-full border-2 border-white bg-slate-50 flex items-center justify-center text-xs text-slate-500 font-bold shadow-md hover:bg-slate-100 cursor-pointer transition-colors" title="Invite Friends">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                    <path d="M5.25 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM2.25 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM18.75 7.5a.75.75 0 0 0-1.5 0v2.25H15a.75.75 0 0 0 0 1.5h2.25v2.25a.75.75 0 0 0 1.5 0v-2.25H21a.75.75 0 0 0 0-1.5h-2.25V7.5Z" />
                                </svg>

                            </div>
                        </div>
                    </div>

                    <!-- Edit View (Hidden by default) -->
                    <div id="trip-badge-edit" class="hidden w-full">
                        <form id="trip-badge-edit-form" class="space-y-4">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="relative">
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Destination Location</label>
                                    <div class="relative">
                                        <span class="absolute left-3.5 top-3 text-slate-400 text-sm">📍</span>
                                        <input type="hidden" id="editTripPlaceId" name="googlePlaceId" value="@(Model.PlacesToVisit.FirstOrDefault()?.GooglePlaceId)" />
                                        <input type="hidden" id="editTripLat" name="latitude" value="@(Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                                        <input type="hidden" id="editTripLng" name="longitude" value="@(Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                                        <input type="hidden" id="editTripAddress" name="formattedAddress" value="@(Model.PlacesToVisit.FirstOrDefault()?.FormattedAddress)" />
                                        <input type="hidden" id="editTripPlaceName" name="placeName" value="@(Model.PlacesToVisit.FirstOrDefault()?.Name)" />
                                        
                                        <input type="text" id="editTripLocationInput" autocomplete="off" placeholder="Where to? (e.g. Vienna, Paris...)"
                                               class="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm placeholder-slate-400 outline-none transition-all"
                                               value="@Model.Title" />
                                    </div>
                                    <div id="edit-trip-suggestions" class="absolute left-0 right-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-xl max-h-60 overflow-y-auto hidden z-50"></div>
                                </div>

                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Short Description</label>
                                    <input type="text" id="editTripDescription" name="description" placeholder="A short description of the trip..."
                                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm placeholder-slate-400 outline-none transition-all"
                                           value="@Model.Description" />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Start Date</label>
                                    <input type="date" id="editTripStartDate" name="startDate" 
                                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-550/20 focus:border-indigo-500 text-sm outline-none transition-all"
                                           value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">End Date</label>
                                    <input type="date" id="editTripEndDate" name="endDate" 
                                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-550/20 focus:border-indigo-500 text-sm outline-none transition-all"
                                           value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                            </div>

                            <div class="flex justify-end space-x-2 pt-2">
                                <button type="button" onclick="exitBadgeEditMode()" 
                                        class="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-600 rounded-xl text-xs sm:text-sm font-semibold transition-all">
                                    Cancel
                                </button>
                                <button type="submit" 
                                        class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-4 py-2 rounded-xl text-xs sm:text-sm font-semibold transition-all">
                                    Save Changes
                                </button>
                            </div>
                        </form>
                    </div>

                </div>

                <!-- 1. PLACES TO VISIT (UNSCHEDULED BUCKET) -->
                <div class="mb-12">
                    <h3 class="text-lg font-extrabold text-slate-900 mb-4 flex items-center">
                        <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Places to Visit (Unscheduled)
                    </h3>
                    @if (Model.PlacesToVisit != null && Model.PlacesToVisit.Count > 0)
                    {
                        <div class="flex flex-wrap gap-3 mb-4">
                            @foreach (var place in Model.PlacesToVisit)
                            {
                                <div class="bg-indigo-50/50 hover:bg-indigo-55 border border-indigo-100 rounded-xl px-4 py-2.5 text-sm font-semibold text-indigo-700 flex items-center transition-all cursor-pointer hover:border-indigo-300" onclick="showPlaceDetailsPopup('@place.GooglePlaceId')">
                                    <span class="mr-2">📍</span> @place.Name
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-xs text-slate-400 mb-4 italic">No unscheduled places added yet.</p>
                    }

                    @await Html.PartialAsync("_InlineAddPlacePartial", new
                    {
                        DayNumber = 0,
                        DayLabel = "Unscheduled",
                        TripId = Model.TripId,
                        TripTitle = Model.Title,
                        TripStartDate = Model.StartDate?.ToString("yyyy-MM-dd"),
                        TripEndDate = Model.EndDate?.ToString("yyyy-MM-dd")
                    })
                </div>

                <!-- 2. DYNAMIC DAILY ITINERARY -->
                <div class="mb-14">
                    <h2 class="text-2xl font-black text-slate-900 mb-8 flex items-center tracking-tight">
                        <svg class="w-6 h-6 mr-2.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                        Daily Itinerary

                    </h2>

                    @if (Model.Days == null || Model.Days.Count == 0)
                    {
                        <div class="bg-slate-50/65 border border-dashed border-slate-200 rounded-2xl p-10 text-center text-slate-500">
                            No dates selected. Set dates to start scheduling your daily activities.
                        </div>
                    }
                    else
                    {
                        <div class="space-y-12">
                            @foreach (var day in Model.Days)
                            {
                                <div class="border-l-2 border-slate-200/80 pl-6 ml-4 relative" id="day-@day.TripDayId">
                                    <!-- Decorative circle marking the timeline -->
                                    <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-indigo-500 ring-4 ring-white"></div>

                                    <!-- Day Header -->
                                    <div class="flex items-baseline justify-between mb-5">
                                        <h3 class="text-lg font-extrabold text-slate-950">@day.DayLabel</h3>
                                        <span class="text-xs text-slate-400 font-semibold tracking-wide">
                                            @(day.Date?.ToString("MMMM dd, yyyy") ?? "")
                                        </span>
                                    </div>

                                    <!-- Activities in the day -->
                                    <div class="activities-container space-y-6 mb-4" data-day-id="@day.TripDayId">
                                        @foreach (var activity in day.Activities)
                                        {
                                            <div class="activity-card bg-white border border-slate-150 rounded-2xl p-5 hover:shadow-md transition-all flex justify-between items-start cursor-grab active:cursor-grabbing" draggable="true" data-activity-id="@activity.TripActivityId">
                                                <!-- Drag handle -->
                                                <div class="mr-3 mt-1 text-slate-300 cursor-grab active:cursor-grabbing hover:text-indigo-500 transition-colors drag-handle shrink-0">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
                                                    </svg>
                                                </div>

                                                <div class="space-y-2 flex-1 pr-4">
                                                    <div class="flex items-center space-x-2">
                                                        <span class="bg-indigo-50 text-indigo-700 text-xs font-semibold px-2.5 py-0.5 rounded-full">
                                                            @(activity.Place?.PrimaryCategory ?? "Activity")
                                                        </span>
                                                        @if (activity.StartTime.HasValue)
                                                        {
                                                            <span class="text-xs text-slate-500 font-medium">
                                                                @activity.StartTime.Value.ToString("hh:mm tt")
                                                                @if (activity.EndTime.HasValue)
                                                                {
                                                                    <span>- @activity.EndTime.Value.ToString("hh:mm tt")</span>
                                                                }
                                                            </span>
                                                        }
                                                    </div>
                                                    <h4 class="font-bold text-slate-900 text-base leading-snug hover:text-indigo-600 hover:underline cursor-pointer" onclick="showPlaceDetailsPopup('@activity.Place?.GooglePlaceId')">@activity.Place?.Name</h4>
                                                    <p class="text-xs text-slate-450">@activity.Place?.FormattedAddress</p>

                                                    @if (activity.ChecklistItems != null && activity.ChecklistItems.Count > 0)
                                                    {
                                                        <ul class="space-y-1 mt-3">
                                                            @foreach (var checklist in activity.ChecklistItems)
                                                            {
                                                                <li class="flex items-center text-xs text-slate-500 font-medium">
                                                                    <input type="checkbox" checked="@checklist.IsCompleted" disabled class="mr-2 rounded text-indigo-600 focus:ring-indigo-500 border-slate-300" />
                                                                    @checklist.Content
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>

                                                <span class="bg-emerald-50 text-emerald-700 border border-emerald-150 text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-md">
                                                    @activity.Status
                                                </span>
                                            </div>

                                            <!-- Display Route information if present -->
                                            @if (activity.RouteToNext != null)
                                            {
                                                <div class="flex items-center space-x-2 text-xs font-semibold text-slate-400 bg-slate-50/50 border border-slate-200/50 rounded-xl px-4 py-2 ml-4 mr-4">
                                                    <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                                    <span>@activity.RouteToNext.TravelMode: @((activity.RouteToNext.DistanceMeters / 1000.0).ToString("N1")) km (@(activity.RouteToNext.DurationSeconds / 60) mins)</span>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <!-- Inline Add Place Form for this day -->
                                    @await Html.PartialAsync("_InlineAddPlacePartial", new
                                    {
                                        DayNumber = day.DayNumber,
                                        DayLabel = day.DayLabel,
                                        TripId = Model.TripId,
                                        TripTitle = Model.Title,
                                        TripStartDate = Model.StartDate?.ToString("yyyy-MM-dd"),
                                        TripEndDate = Model.EndDate?.ToString("yyyy-MM-dd")
                                    })
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- 3. BUDGET WIDGET -->
                <div class="mb-14 border-t border-slate-200/60 pt-10">
                    <h2 class="text-xl font-extrabold text-slate-900 mb-5 tracking-tight flex items-center">
                        <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Trip Financials
                    </h2>

                    <div class="bg-slate-50 border border-slate-200/50 rounded-2xl p-6 w-full sm:w-60 flex flex-col justify-center shadow-sm">
                        <h3 class="font-bold text-slate-500 text-xs uppercase tracking-wider mb-2">Estimated Budget</h3>

                        <!-- Editable Bold Input Area -->
                        <div class="flex items-center text-2xl font-black text-slate-900 mb-3 border-b border-transparent hover:border-slate-300 focus-within:border-indigo-500 transition-colors pb-0.5">
                            <input type="number"
                                   min="0"
                                   max="100000"
                                   step="50"
                                   id="budget"
                                   value="@(Model.Budget ?? 0)"
                                   class="w-full bg-transparent font-black text-slate-900 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                                   placeholder="0">
                            <span class="ml-1 text-slate-400">€</span>
                        </div>

                        <!-- Save Action -->
                        <button type="button" onclick="saveBudget(@Model.TripId)"  class="text-xs font-semibold text-indigo-600 hover:text-indigo-700 flex items-center transition-colors text-left bg-transparent border-none p-0 cursor-pointer">
                            Save budget <span class="ml-1">→</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- 3. RIGHT HAND SIDE INTERACTIVE MAP CONTAINER -->
    <div id="map" class="shrink-0 w-full h-[45%] md:h-full md:w-[58%] bg-slate-100 border-t md:border-t-0 md:border-l border-slate-200/60 relative"></div>

</div>

<!-- PLACE DETAILS FLOATING DRAWER (Wanderlog style) -->
<div id="place-details-modal" class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 w-[calc(100%-2rem)] sm:w-[420px] max-h-[80vh] sm:max-h-[75vh] pointer-events-none flex flex-col hidden transition-opacity duration-300 opacity-0">
    <div id="place-details-card" class="bg-white rounded-3xl shadow-2xl border border-slate-200/80 w-full max-h-full overflow-hidden transform scale-95 opacity-0 transition-all duration-300 flex flex-col pointer-events-auto">
        <!-- Header Image area -->
        <div class="relative h-40 sm:h-48 bg-slate-100 shrink-0">
            <img id="modal-cover-photo" class="w-full h-full object-cover" src="" alt="Place Photo" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
            <button onclick="closePlaceDetailsModal()" class="absolute top-4 right-4 bg-black/40 hover:bg-black/60 text-white rounded-full p-2 transition-colors focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
            <div class="absolute bottom-4 left-6 right-6">
                <span id="modal-category" class="bg-indigo-650 text-white text-[10px] font-extrabold px-2.5 py-1 rounded-full uppercase tracking-wider mb-2 inline-block">Attraction</span>
                <h2 id="modal-title" class="text-lg sm:text-xl font-black text-white leading-tight">Place Name</h2>
            </div>
        </div>

        <!-- Scrollable details container -->
        <div class="p-5 sm:p-6 space-y-5 overflow-y-auto">
            <!-- Loading indicator -->
            <div id="modal-loading" class="flex flex-col items-center justify-center py-12 space-y-3">
                <div class="animate-spin rounded-full h-10 w-10 border-4 border-indigo-500 border-t-transparent"></div>
                <p class="text-sm font-semibold text-slate-500">Fetching details...</p>
            </div>

            <!-- Content -->
            <div id="modal-content" class="space-y-5 hidden">
                <!-- Overview Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pb-6 border-b border-slate-100">
                    <div class="space-y-3">
                        <div class="flex items-center space-x-2">
                            <span id="modal-rating-num" class="text-2xl font-black text-slate-800">0.0</span>
                            <div id="modal-stars" class="flex text-amber-400"></div>
                            <span id="modal-rating-count" class="text-xs text-slate-400 font-semibold">(0 reviews)</span>
                        </div>
                        <div class="flex items-start text-sm text-slate-600">
                            <span class="mr-2 text-base shrink-0">📍</span>
                            <span id="modal-address" class="leading-relaxed">Address info</span>
                        </div>
                    </div>
                    <div class="space-y-2 text-sm text-slate-600 sm:border-l border-slate-100 sm:pl-6 flex flex-col justify-center">
                        <div id="modal-phone-container" class="flex items-center">
                            <span class="mr-2 text-base">📞</span>
                            <span id="modal-phone">No phone number available</span>
                        </div>
                        <div id="modal-website-container" class="flex items-center mt-1">
                            <span class="mr-2 text-base">🌐</span>
                            <a id="modal-website" href="#" target="_blank" class="text-indigo-600 hover:text-indigo-805 hover:underline font-semibold break-all">Visit Website</a>
                        </div>
                    </div>
                </div>

                <!-- Editorial Summary -->
                <div id="modal-summary-container" class="space-y-2 hidden">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">About</h3>
                    <p id="modal-summary" class="text-slate-600 text-sm leading-relaxed"></p>
                </div>

                <!-- Opening Hours -->
                <div id="modal-hours-container" class="space-y-2 border-t border-slate-100 pt-5 hidden">
                    <button onclick="toggleModalHours()" class="w-full flex items-center justify-between text-left text-xs font-bold text-slate-450 uppercase tracking-wider focus:outline-none">
                        <span>Opening Hours</span>
                        <svg id="hours-arrow" class="w-4 h-4 text-slate-505 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    <div id="modal-hours" class="hidden text-xs text-slate-600 space-y-1.5 pt-2 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1"></div>
                </div>

                <!-- Reviews -->
                <div id="modal-reviews-container" class="space-y-4 border-t border-slate-100 pt-5 hidden">
                    <h3 class="text-xs font-bold text-slate-455 uppercase tracking-wider">Recent Reviews</h3>
                    <div id="modal-reviews" class="space-y-4 divide-y divide-slate-100"></div>
                </div>
            </div>
        </div>
        </div>

   </div>
   <script>
    window.TripConfig = {
        googleApiKey: '@Configuration["ApiKeys:GoogleApiKey"]',
        tripId: @Model.TripId,
        latitude: @(Model.Latitude?.ToString("G", System.Globalization.CultureInfo.InvariantCulture) ?? "47.200"),
        longitude: @(Model.Longitude?.ToString("G", System.Globalization.CultureInfo.InvariantCulture) ?? "13.200"),
        hasCoords: @(Model.Latitude.HasValue && Model.Longitude.HasValue ? "true" : "false"),
        firstPlaceId: '@(Model.PlacesToVisit?.FirstOrDefault()?.GooglePlaceId)',
        updateDetailsUrl: '@Url.Action("UpdateTripDetails", "Trip")',
        setBudgetUrl: '@Url.Action("SetBudget", "Trip")',
        places: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (Model.PlacesToVisit ?? new List<PlaceViewModel>())
            .Concat((Model.Days ?? new List<TripDayViewModel>()).SelectMany(d => d.Activities ?? new List<TripActivityViewModel>()).Where(a => a.Place != null).Select(a => a.Place))
            .Where(p => p != null && p.Latitude.HasValue && p.Longitude.HasValue)
            .Select(p => new
            {
                name = p.Name,
                lat = (double)p.Latitude.Value,
                lng = (double)p.Longitude.Value,
                category = p.PrimaryCategory
            })
        ))
    };
    </script>

@section Scripts {
    <script src="~/js/tripScript.js" asp-append-version="true"></script>
    <script async
            src="https://maps.googleapis.com/maps/api/js?key=@Configuration["ApiKeys:GoogleApiKey"]&libraries=places&loading=async&callback=initMap">
    </script>
}