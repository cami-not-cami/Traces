@inject IConfiguration Configuration
@model CreateTripViewModel
@{
    ViewData["Title"] = "Trip Dashboard";
    ViewData["FullBleed"] = true;
}

<!-- ROOT WRAPPER: Fixed height full-screen container to maintain layout -->
<div class="flex flex-col md:flex-row h-[calc(100vh-64px)] w-full overflow-hidden bg-slate-50 text-slate-800 font-sans relative">

    <!-- Mobile Sidebar Backdrop Overlay -->
    <div id="sidebar-overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/40 z-30 hidden transition-opacity duration-300"></div>

    <!-- 1. SIDEBAR (RENDERED VIA PARTIAL VIEW) -->
    <partial name="_SideMenuPartial.cshtml" />

    <!-- 2. MIDDLE DASHBOARD CONTENT CONTAINER -->
    <main class="flex-1 flex flex-col relative overflow-hidden h-[55%] md:h-full bg-white shadow-xl z-10">

        <!-- Fixed View Header -->
        <header class="h-16 bg-slate-50/95 backdrop-blur-md border-b border-slate-200/60 flex items-center justify-between px-4 sm:px-6 sticky top-0 z-20 shrink-0">
            <div class="flex items-center space-x-2 sm:space-x-3 text-sm text-slate-500 font-medium">
                <button onclick="toggleSidebar()" class="md:hidden flex items-center justify-center p-2 rounded-xl text-slate-500 hover:bg-slate-200/60 hover:text-slate-800 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <span class="font-bold text-slate-700">Itinerary Planner</span>
            </div>
            
            <div class="flex items-center space-x-1.5 sm:space-x-3">
                <button class="bg-slate-200/50 hover:bg-slate-200/80 text-slate-700 px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center border border-slate-300/30 transition-all">
                    Trip plan <svg class="w-4 h-4 ml-1.5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>

                @if (Model.TripId == 0)
                {
                    <form asp-controller="Trip" asp-action="Save" method="post" class="inline m-0">
                        <input type="hidden" asp-for="TripId" />
                        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 hover:shadow-lg hover:shadow-emerald-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                            <svg class="w-4 h-4 sm:mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                            </svg>
                            <span class="hidden sm:inline">Save</span>
                        </button>
                    </form>
                }
                
                <button class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                    <svg class="w-4 h-4 sm:mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.73 2.837m0-7.158l-4.73 2.837M19 12a3 3 0 11-6 0 3 3 0 016 0zm-12 6a3 3 0 11-6 0 3 3 0 016 0zm0-12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="hidden sm:inline">Share</span>
                </button>
            </div>
        </header>

        <!-- Main Body Scroll Area -->
        <div class="flex-1 overflow-y-auto">
            <!-- Banner Cover -->
            <div class="h-64 bg-slate-200 w-full bg-cover bg-center relative" style="background-image: url('https://images.unsplash.com/photo-1523482580672-f109ba8cb9be?auto=format&fit=crop&w=1600&q=80');">
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>

            <div class="max-w-3xl mx-auto px-6 -mt-20 relative z-10 pb-20">
                
                <!-- Trip Destination Badge -->
                <div class="bg-white rounded-2xl shadow-xl shadow-slate-100/80 border border-slate-100 p-8 flex flex-col sm:flex-row justify-between items-start sm:items-end mb-12 transform transition-all duration-300 hover:shadow-2xl">
                    <div class="mb-4 sm:mb-0">
                        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-2">@Model.Title</h1>
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p class="text-slate-500 text-sm mb-3 leading-relaxed">@Model.Description</p>
                        }
                        <div class="flex items-center text-slate-500 text-sm font-medium mt-1">
                            <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            @(Model.StartDate?.ToString("MMM dd, yyyy") ?? "Start Date") - @(Model.EndDate?.ToString("MMM dd, yyyy") ?? "End Date")
                        </div>
                    </div>
                    <div class="flex items-center space-x-2">
                        <div class="flex -space-x-2">
                            @foreach (var member in Model.Members.Take(3))
                            {
                                <div class="w-9 h-9 rounded-full border-2 border-white bg-indigo-150 flex items-center justify-center text-xs font-bold text-indigo-700 shadow-md" title="@member.FullName">
                                    @member.FirstName[0]@member.LastName[0]
                                </div>
                            }
                        </div>
                        <div class="w-9 h-9 rounded-full border-2 border-white bg-slate-50 flex items-center justify-center text-xs text-slate-500 font-bold shadow-md hover:bg-slate-100 cursor-pointer transition-colors" title="Invite Friends">
                            +👤
                        </div>
                    </div>
                </div>

                <!-- GLOBAL "ADD TO PLAN" FORM CARD (ALWAYS VISIBLE) -->
                <div class="bg-slate-50 border border-slate-200/80 rounded-2xl p-6 mb-12 shadow-sm">
                    <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-4 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Add to Plan
                    </h3>

                    <form asp-controller="Trip" asp-action="AddActivityToTrip" method="post" id="global-add-form" class="space-y-4">
                        <input type="hidden" name="TripId" value="@Model.TripId" />
                        
                        <!-- Google API auto-populated fields -->
                        <input type="hidden" name="GooglePlaceId" />
                        <input type="hidden" name="Latitude" />
                        <input type="hidden" name="Longitude" />
                        <input type="hidden" name="FormattedAddress" />

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Place Search Input (Google Autocomplete Hooked) -->
                            <div class="md:col-span-2">
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Search Place</label>
                                <input type="text" name="PlaceName" id="global-autocomplete" required placeholder="Search restaurants, tourist attractions, parks..." class="w-full bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-400" />
                            </div>

                            <!-- Target Day Dropdown Selection -->
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Target Day</label>
                                <select name="DayNumber" class="w-full bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                                    <option value="0">Unscheduled (Places to Visit)</option>
                                    @if (Model.Days != null)
                                    {
                                        foreach (var day in Model.Days)
                                        {
                                            <option value="@day.DayNumber">@day.DayLabel</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <!-- Category Select -->
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Category</label>
                                <select name="Category" class="w-full bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                                    <option value="Attraction">Attraction</option>
                                    <option value="Food">Food / Dining</option>
                                    <option value="Lodging">Lodging</option>
                                    <option value="Shopping">Shopping</option>
                                    <option value="Transit">Transit</option>
                                </select>
                            </div>

                            <!-- Start / End Times -->
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Start Time</label>
                                <input type="time" name="StartTime" class="w-full bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all" />
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">End Time</label>
                                <input type="time" name="EndTime" class="w-full bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all" />
                            </div>
                        </div>

                        <!-- Notes Area -->
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">Notes</label>
                            <textarea name="Notes" placeholder="Add entry tickets cost, hotel booking links, reservation details..." rows="2" class="w-full bg-white border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-400"></textarea>
                        </div>

                        <!-- Submit Button -->
                        <div class="flex justify-end pt-2">
                            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-xs font-bold hover:shadow-lg hover:shadow-indigo-500/20 transition-all">
                                Add to Trip Plan
                            </button>
                        </div>
                    </form>
                </div>

                <!-- 1. PLACES TO VISIT (UNSCHEDULED BUCKET) -->
                @if (Model.PlacesToVisit != null && Model.PlacesToVisit.Count > 0)
                {
                    <div class="mb-12">
                        <h3 class="text-lg font-extrabold text-slate-900 mb-4 flex items-center">
                            <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            Places to Visit (Unscheduled)
                        </h3>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var place in Model.PlacesToVisit)
                            {
                                <div class="bg-indigo-50/50 hover:bg-indigo-55 border border-indigo-100 rounded-xl px-4 py-2.5 text-sm font-semibold text-indigo-700 flex items-center transition-all">
                                    <span class="mr-2">📍</span> @place.Name
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- 2. DYNAMIC DAILY ITINERARY -->
                <div class="mb-14">
                    <h2 class="text-2xl font-black text-slate-900 mb-8 flex items-center tracking-tight">
                        <svg class="w-6 h-6 mr-2.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                        Daily Itinerary

                    </h2>

                    @if (Model.Days == null || Model.Days.Count == 0)
                    {
                        <div class="bg-slate-50/65 border border-dashed border-slate-200 rounded-2xl p-10 text-center text-slate-500">
                            No dates selected. Set dates to start scheduling your daily activities.
                        </div>
                    }
                    else
                    {
                        <div class="space-y-12">
                            @foreach (var day in Model.Days)
                            {
                                <div class="border-l-2 border-slate-200/80 pl-6 ml-4 relative">
                                    <!-- Decorative circle marking the timeline -->
                                    <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-indigo-500 ring-4 ring-white"></div>
                                    
                                    <!-- Day Header -->
                                    <div class="flex items-baseline justify-between mb-5">
                                        <h3 class="text-lg font-extrabold text-slate-950">@day.DayLabel</h3>
                                        <span class="text-xs text-slate-400 font-semibold tracking-wide">
                                            @(day.Date?.ToString("MMMM dd, yyyy") ?? "")
                                        </span>
                                    </div>

                                    <!-- Activities in the day -->
                                    <div class="space-y-6 mb-4">
                                        @foreach (var activity in day.Activities)
                                        {
                                            <div class="bg-white border border-slate-150 rounded-2xl p-5 hover:shadow-md transition-all flex justify-between items-start">
                                                <div class="space-y-2 flex-1 pr-4">
                                                    <div class="flex items-center space-x-2">
                                                        <span class="bg-indigo-50 text-indigo-700 text-xs font-semibold px-2.5 py-0.5 rounded-full">
                                                            @(activity.Place?.PrimaryCategory ?? "Activity")
                                                        </span>
                                                        @if (activity.StartTime.HasValue)
                                                        {
                                                            <span class="text-xs text-slate-500 font-medium">
                                                                @activity.StartTime.Value.ToString("hh:mm tt")
                                                                @if (activity.EndTime.HasValue)
                                                                {
                                                                    <span>- @activity.EndTime.Value.ToString("hh:mm tt")</span>
                                                                }
                                                            </span>
                                                        }
                                                    </div>
                                                    <h4 class="font-bold text-slate-900 text-base leading-snug">@activity.Place?.Name</h4>
                                                    <p class="text-xs text-slate-450">@activity.Place?.FormattedAddress</p>
                                                    
                                                    @if (activity.ChecklistItems != null && activity.ChecklistItems.Count > 0)
                                                    {
                                                        <ul class="space-y-1 mt-3">
                                                            @foreach (var checklist in activity.ChecklistItems)
                                                            {
                                                                <li class="flex items-center text-xs text-slate-500 font-medium">
                                                                    <input type="checkbox" checked="@checklist.IsCompleted" disabled class="mr-2 rounded text-indigo-600 focus:ring-indigo-500 border-slate-300" />
                                                                    @checklist.Content
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </div>
                                                
                                                <span class="bg-emerald-50 text-emerald-700 border border-emerald-150 text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-md">
                                                    @activity.Status
                                                </span>
                                            </div>

                                            <!-- Display Route information if present -->
                                            @if (activity.RouteToNext != null)
                                            {
                                                <div class="flex items-center space-x-2 text-xs font-semibold text-slate-400 bg-slate-50/50 border border-slate-200/50 rounded-xl px-4 py-2 ml-4 mr-4">
                                                    <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                                    <span>@activity.RouteToNext.TravelMode: @((activity.RouteToNext.DistanceMeters / 1000.0).ToString("N1")) km (@(activity.RouteToNext.DurationSeconds / 60) mins)</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- 3. BUDGET WIDGET -->
                <div class="mb-14 border-t border-slate-200/60 pt-10">
                    <h2 class="text-xl font-extrabold text-slate-900 mb-5 tracking-tight flex items-center">
                        <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Trip Financials
                    </h2>
                    
                    <div class="bg-slate-50 border border-slate-200/50 rounded-2xl p-6 w-full sm:w-60 flex flex-col justify-center shadow-sm">
                        <h3 class="font-bold text-slate-500 text-xs uppercase tracking-wider mb-2">Estimated Budget</h3>
                        <div class="text-2xl font-black text-slate-900 mb-1.5">
                            @(Model.Budget.HasValue ? Model.Budget.Value.ToString("N2") : "0.00") €
                        </div>
                        <a href="#" class="text-xs font-semibold text-indigo-600 hover:text-indigo-700 flex items-center transition-colors">
                            Manage budget <span class="ml-1">→</span>
                        </a>
                    </div>
                </div>

                <!-- 4. EXPLORE SECTION -->
                <div class="border-t border-slate-200/60 pt-10">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-xl font-extrabold text-slate-900 flex items-center tracking-tight">
                            <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                            Explore Local Guides
                        </h2>
                        <button class="bg-rose-500 hover:bg-rose-600 hover:shadow-lg hover:shadow-rose-500/20 text-white px-4 py-2 rounded-full text-xs font-bold flex items-center shadow-sm transition-all">
                            <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Browse all
                        </button>
                    </div>

                    <!-- Cards Layout Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative">
                        <!-- Card 1 -->
                        <div class="group cursor-pointer">
                            <div class="h-40 bg-slate-100 rounded-2xl mb-3.5 bg-cover bg-center overflow-hidden border border-slate-100 shadow-sm relative group-hover:shadow-md transition-all">
                                <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-105" style="background-image: url('https://images.unsplash.com/photo-1506973035872-a4ec16b8e8d9?auto=format&fit=crop&w=400&q=80');"></div>
                            </div>
                            <h3 class="font-bold text-slate-900 text-sm mb-1 leading-snug group-hover:text-indigo-650 transition-colors">Fly With Liz's Oceania Adventure</h3>
                            <p class="text-xs text-slate-400 mb-3 line-clamp-1">Popular guide by a Wanderlog community member</p>
                            <div class="flex items-center text-xs text-slate-600 font-medium">
                                <img class="w-5.5 h-5.5 rounded-full mr-2 border border-slate-100 shadow-sm" src="https://i.pravatar.cc/100?img=5" alt=""> Fly With Liz
                            </div>
                        </div>

                        <!-- Card 2 -->
                        <div class="group cursor-pointer">
                            <div class="h-40 bg-slate-100 rounded-2xl mb-3.5 bg-cover bg-center overflow-hidden border border-slate-100 shadow-sm relative group-hover:shadow-md transition-all">
                                <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-105" style="background-image: url('https://images.unsplash.com/photo-1542315750-f1c713b6329c?auto=format&fit=crop&w=400&q=80');"></div>
                            </div>
                            <h3 class="font-bold text-slate-900 text-sm mb-1 leading-snug group-hover:text-indigo-650 transition-colors">Allan Watt's Cairns & Great Barrier Reef</h3>
                            <p class="text-xs text-slate-400 mb-3 line-clamp-1">Popular guide by a Wanderlog community member</p>
                            <div class="flex items-center text-xs text-slate-600 font-medium">
                                <img class="w-5.5 h-5.5 rounded-full mr-2 border border-slate-100 shadow-sm" src="https://i.pravatar.cc/100?img=8" alt=""> Allan Watt
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- 3. RIGHT HAND SIDE INTERACTIVE MAP CONTAINER -->
    <div id="map" class="shrink-0 w-full h-[45%] md:h-full md:w-[58%] bg-slate-100 border-t md:border-t-0 md:border-l border-slate-200/60 relative"></div>

</div>

<script>
    let map;
    const lat = @(Model.Latitude?.ToString("G", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
    const lng = @(Model.Longitude?.ToString("G", System.Globalization.CultureInfo.InvariantCulture) ?? "0");

    async function initMap() {
        const { Map } = await google.maps.importLibrary("maps");
        map = new Map(document.getElementById("map"), {
            center: { lat: lat, lng: lng },
            zoom: 13,
        });

        // Initialize autocomplete for the global add form
        const globalInput = document.getElementById('global-autocomplete');
        if (globalInput) {
            const autocomplete = new google.maps.places.Autocomplete(globalInput, {
                fields: ['place_id', 'geometry', 'name', 'formatted_address', 'types'],
                types: ['establishment', 'geocode']
            });

            autocomplete.addListener('place_changed', () => {
                const place = autocomplete.getPlace();
                if (!place.geometry) return;

                const form = document.getElementById('global-add-form');
                if (form) {
                    form.querySelector('input[name="GooglePlaceId"]').value = place.place_id ?? '';
                    form.querySelector('input[name="Latitude"]').value = place.geometry.location.lat();
                    form.querySelector('input[name="Longitude"]').value = place.geometry.location.lng();
                    form.querySelector('input[name="FormattedAddress"]').value = place.formatted_address ?? '';
                    form.querySelector('input[name="PlaceName"]').value = place.name ?? '';

                    // Autofill category if possible
                    const select = form.querySelector('select[name="Category"]');
                    if (place.types && (place.types.includes('restaurant') || place.types.includes('food') || place.types.includes('cafe'))) {
                        select.value = 'Food';
                    } else if (place.types && place.types.includes('lodging')) {
                        select.value = 'Lodging';
                    } else if (place.types && place.types.includes('transit_station')) {
                        select.value = 'Transit';
                    } else if (place.types && (place.types.includes('shopping_mall') || place.types.includes('store'))) {
                        select.value = 'Shopping';
                    } else {
                        select.value = 'Attraction';
                    }
                }
            });
        }
    }
</script>
