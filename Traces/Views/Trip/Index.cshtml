@inject IConfiguration Configuration
@model CreateTripViewModel
@{
    ViewData["Title"] = "Trip Dashboard";
    ViewData["FullBleed"] = true;
}

<style>
    .activity-card.dragging {
        opacity: 0.4;
        border-color: #6366f1 !important; /* indigo-500 */
        box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.1), 0 4px 6px -2px rgba(99, 102, 241, 0.05);
        transform: scale(0.98);
    }

    .activities-container {
        min-height: 80px;
        border: 2px dashed transparent;
        border-radius: 1rem;
        transition: all 0.2s ease;
    }

    .activities-container:empty {
        border: 2px dashed #e2e8f0; /* slate-200 */
        background-color: #f8fafc; /* slate-50 */
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80px;
    }

    .activities-container:empty::after {
        content: "Drag activities here";
        color: #94a3b8; /* slate-400 */
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .activities-container.drag-over {
        background-color: rgba(99, 102, 241, 0.05) !important;
        border: 2px dashed #6366f1 !important; /* indigo-500 */
        padding: 0.75rem;
    }

    .drag-handle {
        align-self: center;
    }
</style>

<!-- ROOT WRAPPER: Fixed height full-screen container to maintain layout -->
<div class="flex flex-col md:flex-row h-[calc(100vh-64px)] w-full overflow-hidden bg-slate-50 text-slate-800 font-sans relative">

    <!-- Mobile Sidebar Backdrop Overlay -->
    <div id="sidebar-overlay" onclick="toggleSidebar()" class="fixed inset-0 bg-black/40 z-30 hidden transition-opacity duration-300"></div>

    <!-- 1. SIDEBAR (RENDERED VIA PARTIAL VIEW) -->
    <partial name="_SideMenuPartial.cshtml" />

    <!-- 2. MIDDLE DASHBOARD CONTENT CONTAINER -->
    <main class="flex-1 flex flex-col relative overflow-hidden h-[55%] md:h-full bg-white shadow-xl z-10">

        <!-- Fixed View Header -->
        <header class="h-16 bg-slate-50/95 backdrop-blur-md border-b border-slate-200/60 flex items-center justify-between px-4 sm:px-6 sticky top-0 z-20 shrink-0">
            <div class="flex items-center space-x-2 sm:space-x-3 text-sm text-slate-500 font-medium">
                <button onclick="toggleSidebar()" class="md:hidden flex items-center justify-center p-2 rounded-xl text-slate-500 hover:bg-slate-200/60 hover:text-slate-800 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <span class="font-bold text-slate-700">Itinerary Planner</span>
            </div>

            <div class="flex items-center space-x-1.5 sm:space-x-3">

                
                @if (Model.TripId == 0 && !Model.ViewOnly)
                {
                    <form asp-controller="Trip" asp-action="Save" method="post" class="inline m-0">
                        <input type="hidden" asp-for="TripId" />
                        <input type="hidden" asp-for="Title" />
                        <input type="hidden" asp-for="Description" />
                        <input type="hidden" asp-for="StartDate" />
                        <input type="hidden" asp-for="EndDate" />
                        <input type="hidden" asp-for="Budget" />

                        @if (Model.PlacesToVisit != null)
                        {
                            for (int i = 0; i < Model.PlacesToVisit.Count; i++)
                            {
                                <input type="hidden" name="PlacesToVisit[@i].GooglePlaceId" value="@Model.PlacesToVisit[i].GooglePlaceId" />
                                <input type="hidden" name="PlacesToVisit[@i].Name" value="@Model.PlacesToVisit[i].Name" />
                                <input type="hidden" name="PlacesToVisit[@i].Latitude" value="@Model.PlacesToVisit[i].Latitude" />
                                <input type="hidden" name="PlacesToVisit[@i].Longitude" value="@Model.PlacesToVisit[i].Longitude" />
                                <input type="hidden" name="PlacesToVisit[@i].FormattedAddress" value="@Model.PlacesToVisit[i].FormattedAddress" />
                                <input type="hidden" name="PlacesToVisit[@i].PrimaryCategory" value="@Model.PlacesToVisit[i].PrimaryCategory" />
                                <input type="hidden" name="PlacesToVisit[@i].City" value="@Model.PlacesToVisit[i].City" />
                                <input type="hidden" name="PlacesToVisit[@i].CoverPhoto" value="@Model.PlacesToVisit[i].CoverPhoto" />
                            }
                        }

                        <button type="submit" class="cursor-pointer bg-emerald-600 hover:bg-emerald-700 hover:shadow-lg hover:shadow-emerald-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                            <svg class="w-4 h-4 sm:mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                            </svg>
                            <span class="hidden sm:inline">Save</span>
                        </button>
                    </form>
                }

                @if (Model.TripId > 0 && !Model.ViewOnly)
                {
                    <button onclick="confirmDeleteTrip(@Model.TripId)" class="bg-rose-600 hover:bg-rose-700 hover:shadow-lg hover:shadow-rose-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                        <svg class="w-3 h-3 sm:mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        <span class="hidden sm:inline"> Delete Trip</span>
                    </button>
                }

                @if (Model.TripId > 0)
                {
                    <a href="@Url.Action("ExportPdf", "Trip", new { tripId = Model.TripId })" class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-3 py-2 sm:px-4 sm:py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center gap-1.5 transition-all no-underline">
                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                        </svg>
                        <span class="hidden sm:inline">Download PDF</span>
                    </a>
                }
            </div>
        </header>

        <!-- Main Body Scroll Area -->
        <div class="flex-1 overflow-y-auto">
            <!-- Banner Cover -->
            @{
                string coverUrl;
                if (ViewBag.CoverPhoto != null)
                {
                    coverUrl = $"https://places.googleapis.com/v1/{ViewBag.CoverPhoto}/media?key={Configuration["ApiKeys:GoogleApiKey"]}&maxWidthPx=1600";
                }
                else
                {
                    var query = Model.Title;
                    if (query != null)
                    {
                        if (query.StartsWith("Trip to ", StringComparison.OrdinalIgnoreCase))
                        {
                            query = query.Substring(8);
                        }

                    }
                    coverUrl = !string.IsNullOrEmpty(query)
                             ? "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?auto=format&fit=crop&w=1600&q=80"
                             : Url.Content("~/default_cover_photo.jpg");

                }
            }
            <div class="h-64 bg-slate-200 w-full bg-cover bg-center relative" style="background-image: url('@coverUrl');">
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>

            <div class="max-w-3xl mx-auto px-6 -mt-20 relative z-10 pb-20">

                <!-- Trip Destination Badge -->
                <div class="bg-white rounded-2xl shadow-xl shadow-slate-100/80 border border-slate-100 p-8 mb-12 transform transition-all duration-300 hover:shadow-2xl relative">
                    
                    <!-- Read-Only View -->
                    <div id="trip-badge-view" class="flex flex-col sm:flex-row justify-between items-start sm:items-end w-full">
                        <div class="mb-4 sm:mb-0 pr-8 relative group flex-1">
                            <div class="flex items-center gap-3">
                                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-2">@Model.Title</h1>
                                @if (!Model.ViewOnly)
                                {
                                    <button onclick="enterBadgeEditMode()" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-slate-105 rounded-lg transition-all" title="Edit Trip Details">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                        </svg>
                                    </button>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <p class="text-slate-500 text-sm mb-3 leading-relaxed">@Model.Description</p>
                            }
                            <div class="flex items-center text-slate-500 text-sm font-medium mt-1">
                                <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                @(Model.StartDate?.ToString("MMM dd, yyyy") ?? "Start Date") - @(Model.EndDate?.ToString("MMM dd, yyyy") ?? "End Date")
                            </div>
                        </div>
                        <div class="flex items-center space-x-2 shrink-0">
                            <div class="flex -space-x-2">
                                @foreach (var member in Model.Members.Take(3))
                                {
                                    var initial1 = !string.IsNullOrEmpty(member.Email) ? member.Email[0].ToString() : "";
                                   
                                    var initials = (initial1).ToUpper();
                                    if (string.IsNullOrEmpty(initials)) initials = "U";
                                    <div class="w-9 h-9 rounded-full border-2 border-white bg-indigo-150 flex items-center justify-center text-xs font-bold text-indigo-700 shadow-md" title="@member.Email">
                                        @initials
                                    </div>
                                }
                            </div>
                            @if (!Model.ViewOnly)
                            {
                                <div onclick="openInviteModal()" class="w-9 h-9 rounded-full border-2 border-white bg-slate-50 flex items-center justify-center text-xs text-slate-500 font-bold shadow-md hover:bg-slate-100 cursor-pointer transition-colors" title="Invite Friends">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                        <path d="M5.25 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM2.25 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM18.75 7.5a.75.75 0 0 0-1.5 0v2.25H15a.75.75 0 0 0 0 1.5h2.25v2.25a.75.75 0 0 0 1.5 0v-2.25H21a.75.75 0 0 0 0-1.5h-2.25V7.5Z" />
                                    </svg>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Edit View (Hidden by default) -->
                    <div id="trip-badge-edit" class="hidden w-full">
                        <form id="trip-badge-edit-form" class="space-y-4">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="relative">
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Destination Location</label>
                                    <div class="relative">
                                        <span class="absolute left-3.5 top-3 text-slate-400 text-sm">📍</span>
                                        <input type="hidden" id="editTripPlaceId" name="googlePlaceId" value="@(Model.PlacesToVisit.FirstOrDefault()?.GooglePlaceId)" />
                                        <input type="hidden" id="editTripLat" name="latitude" value="@(Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                                        <input type="hidden" id="editTripLng" name="longitude" value="@(Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                                        <input type="hidden" id="editTripAddress" name="formattedAddress" value="@(Model.PlacesToVisit.FirstOrDefault()?.FormattedAddress)" />
                                        <input type="hidden" id="editTripPlaceName" name="placeName" value="@(Model.PlacesToVisit.FirstOrDefault()?.Name)" />
                                        
                                        <input type="text" id="editTripLocationInput" autocomplete="off" placeholder="Where to? (e.g. Vienna, Paris...)"
                                               class="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm placeholder-slate-400 outline-none transition-all"
                                               value="@Model.Title" />
                                    </div>
                                    <div id="edit-trip-suggestions" class="absolute left-0 right-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-xl max-h-60 overflow-y-auto hidden z-50"></div>
                                </div>

                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Short Description</label>
                                    <input type="text" id="editTripDescription" name="description" placeholder="A short description of the trip..."
                                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm placeholder-slate-400 outline-none transition-all"
                                           value="@Model.Description" />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Start Date</label>
                                    <input type="date" id="editTripStartDate" name="startDate" 
                                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-550/20 focus:border-indigo-500 text-sm outline-none transition-all"
                                           value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">End Date</label>
                                    <input type="date" id="editTripEndDate" name="endDate" 
                                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-550/20 focus:border-indigo-500 text-sm outline-none transition-all"
                                           value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                            </div>

                            <div class="flex justify-end space-x-2 pt-2">
                                <button type="button" onclick="exitBadgeEditMode()" 
                                        class="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-600 rounded-xl text-xs sm:text-sm font-semibold transition-all">
                                    Cancel
                                </button>
                                <button type="submit" 
                                        class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-4 py-2 rounded-xl text-xs sm:text-sm font-semibold transition-all">
                                    Save Changes
                                </button>
                            </div>
                        </form>
                    </div>

                </div>

                <!-- 1. PLACES TO VISIT (UNSCHEDULED BUCKET) -->
                <div class="mb-12">
                    <h3 class="text-lg font-extrabold text-slate-900 mb-4 flex items-center">
                        <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Places to Visit (Unscheduled)
                    </h3>
                    <div id="unscheduled-places-container" class="flex flex-wrap gap-3 mb-4 @(Model.PlacesToVisit != null && Model.PlacesToVisit.Count > 0 ? "" : "hidden")">
                        @if (Model.PlacesToVisit != null)
                        {
                            foreach (var place in Model.PlacesToVisit)
                            {
                                <div data-place-id="@place.GooglePlaceId" class="bg-indigo-50/50 hover:bg-indigo-55 border border-indigo-100 rounded-xl px-4 py-2.5 text-sm font-semibold text-indigo-700 flex items-center transition-all cursor-pointer hover:border-indigo-300" onclick="showPlaceDetailsPopup('@place.GooglePlaceId')">
                                    <span class="mr-2">📍</span> @place.Name
                                </div>
                            }
                        }
                    </div>
                    <p id="no-unscheduled-places-msg" class="text-xs text-slate-400 mb-4 italic @(Model.PlacesToVisit != null && Model.PlacesToVisit.Count > 0 ? "hidden" : "")">No unscheduled places added yet.</p>

                    @if (!Model.ViewOnly)
                    {
                        @await Html.PartialAsync("_InlineAddPlacePartial", new
                        {
                            DayNumber = 0,
                            DayLabel = "Unscheduled",
                            TripId = Model.TripId,
                            TripTitle = Model.Title,
                            TripStartDate = Model.StartDate?.ToString("yyyy-MM-dd"),
                            TripEndDate = Model.EndDate?.ToString("yyyy-MM-dd")
                        })
                    }
                </div>

                <!-- 2. DYNAMIC DAILY ITINERARY -->
                <div class="mb-14">
                    <h2 class="text-2xl font-black text-slate-900 mb-8 flex items-center tracking-tight">
                        <svg class="w-6 h-6 mr-2.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                        Daily Itinerary

                    </h2>

                    @if (Model.Days == null || Model.Days.Count == 0)
                    {
                        <div class="bg-slate-50/65 border border-dashed border-slate-200 rounded-2xl p-10 text-center text-slate-500">
                            No dates selected. Set dates to start scheduling your daily activities.
                        </div>
                    }
                    else
                    {
                        <div class="space-y-12">
                            @foreach (var day in Model.Days)
                            {
                                <div class="border-l-2 border-slate-200/80 pl-6 ml-4 relative" id="day-@day.TripDayId">
                                    <!-- Decorative circle marking the timeline -->
                                    <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-indigo-500 ring-4 ring-white"></div>

                                    <!-- Day Header -->
                                    <div class="flex items-baseline justify-between mb-5">
                                        <h3 class="text-lg font-extrabold text-slate-950">@day.DayLabel</h3>
                                        <span class="text-xs text-slate-400 font-semibold tracking-wide">
                                            @(day.Date?.ToString("MMMM dd, yyyy") ?? "")
                                        </span>
                                    </div>

                                    <!-- Activities in the day -->
                                    <div class="activities-container space-y-6 mb-4 animate-in fade-in-50 duration-200" data-day-id="@day.TripDayId">
                                        @foreach (var item in day.TimelineItems)
                                        {
                                            if (item.Type == "Activity" && item.Activity != null)
                                            {
                                                var activity = item.Activity;
                                                <div class="timeline-card activity-card bg-white border border-slate-150 rounded-2xl p-5 hover:shadow-md transition-all flex justify-between items-start @(Model.ViewOnly ? "" : "cursor-grab active:cursor-grabbing")" draggable="@(Model.ViewOnly ? "false" : "true")" data-timeline-id="@item.Id" data-timeline-type="Activity" data-google-place-id="@activity.Place?.GooglePlaceId">
                                                    <!-- Drag handle -->
                                                    @if (!Model.ViewOnly)
                                                    {
                                                        <div class="mr-3 mt-1 text-slate-300 cursor-grab active:cursor-grabbing hover:text-indigo-500 transition-colors drag-handle shrink-0">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
                                                            </svg>
                                                        </div>
                                                    }

                                                    <div class="space-y-2 flex-1 pr-4">
                                                        <div class="flex items-center space-x-2">
                                                            <span class="bg-indigo-50 text-indigo-700 text-xs font-semibold px-2.5 py-0.5 rounded-full">
                                                                @(activity.Place?.PrimaryCategory ?? "Activity")
                                                            </span>
                                                            @if (activity.StartTime.HasValue)
                                                            {
                                                                <span class="text-xs text-slate-500 font-medium">
                                                                    @activity.StartTime.Value.ToString("hh:mm tt")
                                                                    @if (activity.EndTime.HasValue)
                                                                    {
                                                                        <span>- @activity.EndTime.Value.ToString("hh:mm tt")</span>
                                                                    }
                                                                </span>
                                                            }
                                                        </div>
                                                        <h4 class="font-bold text-slate-900 text-base leading-snug hover:text-indigo-600 hover:underline cursor-pointer" onclick="showPlaceDetailsPopup('@activity.Place?.GooglePlaceId')">@activity.Place?.Name</h4>
                                                        <p class="text-xs text-slate-450">@activity.Place?.FormattedAddress</p>
                                                    </div>

                                                    <div class="flex items-center space-x-2 shrink-0">
                                                        <span class="bg-emerald-50 text-emerald-700 border border-emerald-150 text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-md">
                                                            @activity.Status
                                                        </span>
                                                        @if (!Model.ViewOnly)
                                                        {
                                                            <button type="button" onclick="deleteTimelineItem(@item.Id, 'Activity')" class="text-slate-400 hover:text-red-500 transition-colors p-1.5 rounded-lg hover:bg-slate-100" title="Delete Place">
                                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                                </svg>
                                                            </button>
                                                        }
                                                    </div>
                                                </div>

                                                <!-- Display Route information if present -->
                                                if (activity.RouteToNext != null)
                                                {
                                                    <div class="route-badge-container flex items-center space-x-2 text-xs font-semibold text-slate-400 bg-slate-50/55 border border-slate-200/50 rounded-xl px-4 py-2 ml-4 mr-4 animate-in fade-in-50" data-from-activity-id="@activity.TripActivityId" data-to-activity-id="@activity.RouteToNext.ToActivityFk">
                                                        @if (activity.RouteToNext.TravelMode == "WALK")
                                                        {
                                                            <svg class="w-4 h-4 text-indigo-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                                                                <circle cx="13" cy="4" r="1" />
                                                                <path d="M7 21l3-4" />
                                                                <path d="M16 21l-2-5-2-3 1-4" />
                                                                <path d="M6 12l2-3 4-1 3 3 3 1" />
                                                            </svg>
                                                        }
                                                        else
                                                        {
                                                            <svg class="w-4 h-4 text-indigo-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                                                                <circle cx="7" cy="17" r="2" />
                                                                <circle cx="17" cy="17" r="2" />
                                                                <path d="M5 17h-2v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2m-4 0h-6m-6-6h15" />
                                                            </svg>
                                                        }
                                                        @if (Model.ViewOnly)
                                                        {
                                                            <span class="text-slate-500 font-bold mr-1">
                                                                @(activity.RouteToNext.TravelMode == "WALK" ? "Walk" : "Drive")
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <select onchange="changeTravelMode(@activity.TripActivityId, @activity.RouteToNext.ToActivityFk, this.value)" class="bg-transparent border-none text-slate-500 font-bold focus:outline-none cursor-pointer outline-none mr-1">
                                                                <option value="DRIVE" selected="@(activity.RouteToNext.TravelMode == "DRIVE" ? "selected" : null)">Drive</option>
                                                                <option value="WALK" selected="@(activity.RouteToNext.TravelMode == "WALK" ? "selected" : null)">Walk</option>
                                                            </select>
                                                        }
                                                        <span class="text-slate-400">|</span>
                                                        <span>@((activity.RouteToNext.DistanceMeters / 1000.0).ToString("N1")) km (@(activity.RouteToNext.DurationSeconds / 60) mins)</span>
                                                    </div>
                                                }
                                            }
                                            else if (item.Type == "Note" && item.Note != null)
                                            {
                                                <div class="timeline-card activity-card bg-slate-50 border border-slate-200 rounded-2xl p-5 hover:shadow-md transition-all flex justify-between items-start @(Model.ViewOnly ? "" : "cursor-grab active:cursor-grabbing")" draggable="@(Model.ViewOnly ? "false" : "true")" data-timeline-id="@item.Id" data-timeline-type="Note">
                                                    <div class="flex items-start space-x-3 flex-1 pr-4">
                                                        @if (!Model.ViewOnly)
                                                        {
                                                            <div class="mt-1 text-slate-300 cursor-grab active:cursor-grabbing hover:text-indigo-500 transition-colors drag-handle shrink-0">
                                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
                                                                </svg>
                                                            </div>
                                                        }
                                                        <div class="w-8 h-8 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0">
                                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                                            </svg>
                                                        </div>
                                                        <div class="text-sm text-slate-650 leading-relaxed pt-0.5 whitespace-pre-line">
                                                            @item.Note.Content
                                                        </div>
                                                    </div>
                                                    @if (!Model.ViewOnly)
                                                    {
                                                        <button type="button" onclick="deleteTimelineItem(@item.Id, 'Note')" class="text-slate-400 hover:text-red-500 transition-colors p-1.5 rounded-lg hover:bg-slate-100" title="Delete Note">
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                            </svg>
                                                        </button>
                                                    }
                                                </div>
                                            }
                                            else if (item.Type == "Checklist" && item.Checklist != null)
                                            {
                                                <div class="timeline-card activity-card bg-slate-50 border border-slate-200 rounded-2xl p-5 hover:shadow-md transition-all flex justify-between items-start @(Model.ViewOnly ? "" : "cursor-grab active:cursor-grabbing")" draggable="@(Model.ViewOnly ? "false" : "true")" data-timeline-id="@item.Id" data-timeline-type="Checklist">
                                                    <div class="flex items-start space-x-3 flex-1 pr-4">
                                                        @if (!Model.ViewOnly)
                                                        {
                                                            <div class="mt-1 text-slate-300 cursor-grab active:cursor-grabbing hover:text-indigo-500 transition-colors drag-handle shrink-0">
                                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16" />
                                                                </svg>
                                                            </div>
                                                        }
                                                        <div class="w-8 h-8 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0">
                                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                                                            </svg>
                                                        </div>
                                                        <div class="flex-1 pt-0.5">
                                                            <h4 class="font-bold text-slate-800 text-sm mb-3">@item.Checklist.Title</h4>
                                                            <ul class="space-y-2.5 mb-3 checklist-items-list" data-checklist-id="@item.Id">
                                                                @foreach (var chItem in item.Checklist.ChecklistItems.OrderBy(ci => ci.OrderIndex))
                                                                {
                                                                    <li class="flex items-center text-xs text-slate-600" data-item-id="@chItem.ChItIdPk">
                                                                        <input type="checkbox" @(chItem.IsCompleted ? "checked" : "") onchange="toggleChecklistItem(this)" class="mr-2.5 h-4 w-4 rounded text-indigo-600 focus:ring-indigo-500 border-slate-300 @(Model.ViewOnly ? "pointer-events-none" : "")" />
                                                                        <span class="@(chItem.IsCompleted ? "line-through text-slate-400" : "text-slate-700 font-medium")">@chItem.Content</span>
                                                                    </li>
                                                                }
                                                            </ul>
                                                            @if (!Model.ViewOnly)
                                                            {
                                                                <div class="flex items-center space-x-2 mt-2 pt-1.5 border-t border-slate-200/50">
                                                                    <input type="text" placeholder="Add some items..." class="bg-white border border-slate-200 rounded-lg px-2.5 py-1 text-xs w-full max-w-[200px] focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" onkeydown="handleAddChecklistItemKeyDown(event, @item.Id)" />
                                                                    <button type="button" onclick="submitNewChecklistItem(this, @item.Id)" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 px-2 py-1">Add</button>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                    @if (!Model.ViewOnly)
                                                    {
                                                        <button type="button" onclick="deleteTimelineItem(@item.Id, 'Checklist')" class="text-slate-400 hover:text-red-500 transition-colors p-1.5 rounded-lg hover:bg-slate-100" title="Delete Checklist">
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                            </svg>
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>

                                    @if (!Model.ViewOnly)
                                    {
                                        <!-- Unified Day Action Bar -->
                                        @await Html.PartialAsync("_DayActionBarPartial", new
                                        {
                                            DayNumber = day.DayNumber,
                                            DayLabel = day.DayLabel,
                                            TripDayId = day.TripDayId,
                                            TripId = Model.TripId,
                                            TripTitle = Model.Title,
                                            TripStartDate = Model.StartDate?.ToString("yyyy-MM-dd"),
                                            TripEndDate = Model.EndDate?.ToString("yyyy-MM-dd")
                                        })
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- 3. BUDGET WIDGET -->
                @{
                    var totalSpent = Model.Expenses?.Sum(e => e.Amount) ?? 0m;
                    var budgetLimit = (decimal)(Model.Budget ?? 0.0);
                    var remaining = budgetLimit - totalSpent;
                    var percentUsed = budgetLimit > 0 ? (double)(totalSpent / budgetLimit * 100) : 0;
                    if (percentUsed > 100) percentUsed = 100;
                    var progressColorClass = percentUsed >= 90 ? "bg-rose-500" : percentUsed >= 75 ? "bg-amber-500" : "bg-emerald-500";
                }
                <div class="mb-14 border-t border-slate-200/60 pt-10">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-xl font-extrabold text-slate-900 tracking-tight flex items-center">
                            <svg class="w-5.5 h-5.5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Trip Financials
                        </h2>
                        @if (!Model.ViewOnly && Model.TripId > 0)
                        {
                            <button onclick="openAddExpenseModal()" class="bg-indigo-600 hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 text-white px-3.5 py-2 rounded-xl text-xs sm:text-sm font-semibold flex items-center transition-all">
                                <svg class="w-4 h-4 mr-1.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                </svg>
                                Add expense
                            </button>
                        }
                    </div>

                    @if (Model.TripId == 0)
                    {
                        <p class="text-sm text-slate-450 italic">Save the trip first to manage your budget and track expenses.</p>
                    }
                    else
                    {
                        <!-- Budget Summary Card -->
                        <div class="bg-slate-50 border border-slate-200/50 rounded-2xl p-6 shadow-sm mb-6 flex flex-col gap-5">
                            <div class="space-y-4">
                                <div class="flex flex-wrap items-center gap-x-12 gap-y-6">
                                    <div class="shrink-0">
                                        <h3 class="font-bold text-slate-500 text-xs uppercase tracking-wider mb-1">Total Spent</h3>
                                        <span id="total-spent-display" class="text-xl sm:text-2xl font-black text-slate-900 whitespace-nowrap">@totalSpent.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                                    </div>
                                    <div class="shrink-0">
                                        <h3 class="font-bold text-slate-500 text-xs uppercase tracking-wider mb-1">Limit</h3>
                                        <div class="flex items-center text-xl sm:text-2xl font-black text-slate-900 border-b border-transparent hover:border-slate-300 focus-within:border-indigo-500 transition-colors pb-0.5 max-w-[140px] whitespace-nowrap">
                                            <input type="number"
                                                   min="0"
                                                   max="100000"
                                                   step="50"
                                                   id="budget"
                                                   value="@(Model.Budget ?? 0)"
                                                   class="w-full bg-transparent font-black text-slate-900 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                                                   placeholder="0"
                                                   onchange="saveBudget(@Model.TripId)"
                                                   @(Model.ViewOnly ? "disabled" : "")>
                                            <span class="ml-1 text-slate-450">€</span>
                                        </div>
                                    </div>
                                    <div class="shrink-0">
                                        <h3 class="font-bold text-slate-500 text-xs uppercase tracking-wider mb-1">Remaining</h3>
                                        <span id="remaining-display" class="text-xl sm:text-2xl font-black @(remaining < 0 ? "text-rose-600" : "text-slate-900") whitespace-nowrap">
                                            @remaining.ToString("C", new System.Globalization.CultureInfo("de-DE"))
                                        </span>
                                    </div>
                                </div>

                                <!-- Progress bar -->
                                <div class="w-full bg-slate-200 rounded-full h-3 overflow-hidden">
                                    <div id="budget-progress-bar" class="h-full @progressColorClass transition-all duration-500" style="width: @(percentUsed)%"></div>
                                </div>

                                <!-- Personal share and balance -->
                                <div class="border-t border-slate-200/50 pt-4 flex flex-wrap gap-x-12 gap-y-4">
                                    <div class="shrink-0">
                                        <h4 class="font-bold text-slate-500 text-[10px] uppercase tracking-wider mb-0.5">Your Share</h4>
                                        <span id="your-share-display" class="text-base font-bold text-slate-800 whitespace-nowrap">€0,00</span>
                                    </div>
                                    <div class="shrink-0">
                                        <h4 class="font-bold text-slate-500 text-[10px] uppercase tracking-wider mb-0.5">Your Balance</h4>
                                        <span id="your-balance-display" class="text-base font-bold text-slate-800 whitespace-nowrap">Settled</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions Row at the bottom -->
                            <div class="border-t border-slate-200/60 pt-4 flex flex-wrap gap-x-6 gap-y-2">
                                <button onclick="openBreakdownModal()" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 flex items-center transition-colors text-left bg-transparent border-none p-0 cursor-pointer">
                                    <svg class="w-4.5 h-4.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />
                                    </svg>
                                    View breakdown
                                </button>
                                <button onclick="openInviteModal()" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 flex items-center transition-colors text-left bg-transparent border-none p-0 cursor-pointer">
                                    <svg class="w-4.5 h-4.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                                    </svg>
                                    Add tripmate
                                </button>
                            </div>
                        </div>

                        <!-- Expenses List Section -->
                        <div class="space-y-4">
                            <div class="flex justify-between items-center border-b border-slate-200 pb-2">
                                <h3 class="font-bold text-slate-800 text-sm">Expenses</h3>
                                <span class="text-xs text-slate-400 font-semibold" id="expenses-count-display">0 items</span>
                            </div>

                            <div id="expenses-container" class="space-y-3 max-h-96 overflow-y-auto pr-1">
                                <p id="no-expenses-msg" class="text-xs text-slate-400 italic py-4 hidden">No expenses added to this trip yet.</p>
                            </div>
                        </div>
                    }
                </div>


            </div>
        </div>
    </main>

    <!-- 3. RIGHT HAND SIDE INTERACTIVE MAP CONTAINER -->
    <div id="map" class="shrink-0 w-full h-[45%] md:h-full md:w-[58%] bg-slate-100 border-t md:border-t-0 md:border-l border-slate-200/60 relative"></div>

</div>

<!-- PLACE DETAILS FLOATING DRAWER -->
<div id="place-details-modal" class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 w-[calc(100%-2rem)] sm:w-[420px] max-h-[80vh] sm:max-h-[75vh] pointer-events-none flex flex-col hidden transition-opacity duration-300 opacity-0">
    <div id="place-details-card" class="bg-white rounded-3xl shadow-2xl border border-slate-200/80 w-full max-h-full overflow-hidden transform scale-95 opacity-0 transition-all duration-300 flex flex-col pointer-events-auto">
        <!-- Header Image area -->
        <div class="relative h-40 sm:h-48 bg-slate-100 shrink-0">
            <img id="modal-cover-photo" class="w-full h-full object-cover" src="" alt="Place Photo" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
            <button onclick="closePlaceDetailsModal()" class="absolute top-4 right-4 bg-black/40 hover:bg-black/60 text-white rounded-full p-2 transition-colors focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
            <div class="absolute bottom-4 left-6 right-6">
                <span id="modal-category" class="bg-indigo-650 text-white text-[10px] font-extrabold px-2.5 py-1 rounded-full uppercase tracking-wider mb-2 inline-block">Attraction</span>
                <h2 id="modal-title" class="text-lg sm:text-xl font-black text-white leading-tight">Place Name</h2>
            </div>
        </div>

        <!-- Scrollable details container -->
        <div class="p-5 sm:p-6 space-y-5 overflow-y-auto">
            <!-- Loading indicator -->
            <div id="modal-loading" class="flex flex-col items-center justify-center py-12 space-y-3">
                <div class="animate-spin rounded-full h-10 w-10 border-4 border-indigo-500 border-t-transparent"></div>
