@model CreateTripViewModel

<div class="mb-6">
    <button onclick="toggleSidebarSection(this)" class="w-[calc(100%-24px)] mx-3 flex items-center px-3.5 py-2.5 text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 font-semibold text-sm rounded-xl sidebar-btn transition-all duration-300">
        <svg class="w-4 h-4 mr-2 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
        <span class="sidebar-text">My Trips</span>
    </button>
 
<!-- Saved Trips List -->
@if (ViewBag.UserTrips != null)
{
    var userTrips = (List<Trip>)ViewBag.UserTrips;
    if (userTrips.Any())
    {
        <div class="px-6 py-3 border-b border-slate-200/60 sidebar-text">
            <ul class="mt-2 space-y-1 max-h-36 overflow-y-auto">
                @foreach (var t in userTrips)
                {
                    <li id="sidebar-row">
                        <a href="@Url.Action("Index", "Trip", new { tripId = t.TrIdPk })"
                           class="flex items-center py-1.5 px-3 text-xs font-semibold rounded-xl transition-all @(Model.TripId == t.TrIdPk ? "bg-indigo-50 text-indigo-700" : "text-slate-600 hover:text-indigo-600 hover:bg-slate-200/55")">
                            <span class="mr-2">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                    <path d="M3.478 2.404a.75.75 0 0 0-.926.941l2.432 7.905H13.5a.75.75 0 0 1 0 1.5H4.984l-2.432 7.905a.75.75 0 0 0 .926.94 60.519 60.519 0 0 0 18.445-8.986.75.75 0 0 0 0-1.218A60.517 60.517 0 0 0 3.478 2.404Z" />
                                </svg>
                            </span>
                            <span class="truncate">@t.Title</span>
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
}
</div>
