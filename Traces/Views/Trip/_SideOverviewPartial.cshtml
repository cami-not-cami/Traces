@model CreateTripViewModel

<div class="mb-6">
    <button class="w-[calc(100%-24px)] mx-3 flex items-center px-3.5 py-2.5 bg-indigo-50 text-indigo-700 font-semibold text-sm rounded-xl sidebar-btn transition-all duration-300 hover:bg-indigo-100/70">
        <svg class="w-4 h-4 mr-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
        <span class="sidebar-text">Overview</span>
    </button>
    <ul class="mt-1.5 space-y-0.5 sidebar-sublist">
        <li><a href="#explore" class="block mx-3 pl-10 pr-4 py-1.5 text-sm font-semibold text-slate-900 hover:text-indigo-600 hover:bg-slate-200/55 rounded-xl transition-all">Explore</a></li>
        <li><a href="#notes" class="block mx-3 pl-10 pr-4 py-1.5 text-sm font-medium text-slate-500 hover:text-indigo-600 hover:bg-slate-200/55 rounded-xl transition-all">Notes</a></li>
        <li><a href="#places" class="block mx-3 pl-10 pr-4 py-1.5 text-sm font-medium text-slate-500 hover:text-indigo-600 hover:bg-slate-200/55 rounded-xl transition-all">Places to visit</a></li>
    </ul>
</div>