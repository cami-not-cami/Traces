@model ExploreCardViewModel

@* read countries from activities and display top 3, taking the route from other users *@
<div class="group bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-200 flex flex-col h-full">
	<div class="h-48 bg-slate-200 relative overflow-hidden shrink-0">
		<img src="@Model.CoverPhoto"
			 alt="@Model.CountryName" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
		<span class="absolute top-3 right-3 bg-white/90 text-xs font-bold px-2 py-1 rounded-md text-slate-800 shadow-sm">@Model.CardLabel</span>
	</div>
	<div class="p-5 flex-1 flex flex-col justify-between bg-white">
		<div>
			<h3 class="font-bold text-lg text-gray-900 mb-1">Country: @Model.CountryName</h3>
			<p class="text-xs text-gray-500 leading-relaxed">@Model.Description</p>
		</div>
		<span class="text-xs font-semibold text-indigo-600 mt-4 inline-flex items-center group-hover:translate-x-1 transition-transform">
			View Route Ideas &rarr;
		</span>
	</div>
</div>