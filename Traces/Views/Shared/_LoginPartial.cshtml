@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="flex space-x-6 flex-grow">
@if (SignInManager.IsSignedIn(User))
{
    <li >
            <a class="text-gray-600 inline-block align-baseline align-text-bottom hover:text-gray-900 font-medium px-3 py-2 rounded-md transition-colors" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @User.Identity?.Name!</a>
    </li>
    <li >

            <form class="" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="ttext-white bg-brand box-border border border-transparent hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none">Logout</button>
        </form>
    </li>
}
else
{

    <li class="nav-item">
            <a class="text-gray-600 hover:text-gray-900 font-medium px-3 py-2 rounded-md transition-colors" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
            <a class="text-gray-600 hover:text-gray-900 font-medium px-3 py-2 rounded-md transition-colors" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
